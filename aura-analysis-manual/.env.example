# Aura Analysis Free Manual Dashboard — environment variables
# Copy to .env and fill in values. For Vercel, set these in Project Settings → Environment Variables.

# MySQL (required for API)
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=aura_fx
# Optional:
# MYSQL_PORT=3306
# MYSQL_SSL=false
# DATABASE_URL=mysql://user:pass@host:3306/dbname

# JWT (required for auth)
JWT_SECRET=your-secret-key-min-32-chars
# or JWT_SIGNING_KEY=...

# Frontend (optional; empty = same-origin proxy)
# REACT_APP_API_URL=

# Auth: must match main Aura FX app (no separate login in Aura Analysis)
# REACT_APP_AUTH_TOKEN_KEY=token
# REACT_APP_MAIN_LOGIN_URL=/
