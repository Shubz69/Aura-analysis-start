# Aura FX auth (required — same as main site)
# JWT secret used to verify tokens from the main Aura FX site
JWT_SECRET=your-jwt-secret
# Or: JWT_SIGNING_KEY=your-jwt-secret

# Database — MySQL (same as main Aura FX app)
# Option A: single URL
# DATABASE_URL=mysql://user:password@host:3306/database

# Option B: separate vars
MYSQL_HOST=localhost
MYSQL_USER=your-user
MYSQL_PASSWORD=your-password
MYSQL_DATABASE=your-database
# MYSQL_PORT=3306
# MYSQL_SSL=false

# Optional: app URL for returnUrl after main site login (default: uses NEXT_PUBLIC_VERCEL_URL)
# NEXT_PUBLIC_APP_URL=https://aura-analysis-start.vercel.app

# Optional: storage key for JWT (must match main site)
# NEXT_PUBLIC_AUTH_TOKEN_KEY=token
