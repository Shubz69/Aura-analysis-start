# Standalone test mode: app opens to dashboard with mock user (default)
# Set to "false" to enable /api/aura-analysis/me token check (still no external redirects)
# NEXT_PUBLIC_BYPASS_AUTH=false

# API/DB (optional — for /api/aura-analysis/me when bypass is false)
JWT_SECRET=your-jwt-secret
# JWT_SIGNING_KEY=your-jwt-secret

# Database (optional)
# DATABASE_URL=mysql://user:password@host:3306/database
# Or:
MYSQL_HOST=localhost
MYSQL_USER=your-user
MYSQL_PASSWORD=your-password
MYSQL_DATABASE=your-database

# Optional: storage key for JWT
# NEXT_PUBLIC_AUTH_TOKEN_KEY=token
